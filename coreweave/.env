# HuggingFace
export HF_DATASETS_CACHE="/tmp/hf_datasets_cache"
export HF_HOME="/tmp/hf_home"
export TRANSFORMERS_CACHE="/tmp/transformers_cache"
export TOKENIZERS_PARALLELISM=false # disables tokenizer parallelism to prevent deadlocks when processes are forked (e.g. by accelerate)

# WANDB
export WANDB_DIR="/tmp/wandb"
export WANDB_CACHE_DIR="/tmp/wandb_cache"
export WANDB_CONFIG_DIR="/tmp/wandb_config"
export WANDB_DATA_DIR="/tmp/wandb_data"
export WANDB_ARTIFACT_DIR="/tmp/wandb_artifacts"

# TODO - fill wandb API key
export WANDB_API_KEY=

# NVIDIA
export CUDA_CACHE_PATH="/tmp/.nv/ComputeCache"
export XDG_CACHE_HOME="/tmp/"
